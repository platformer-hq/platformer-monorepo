{
  "$schema": "https://v2-9-5.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "@tma.js/vue-kit#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@workspace/admin#dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": [
        "@tma.js/vue-kit#build"
      ]
    },
    "@workspace/launcher#dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": [
        "@tma.js/vue-kit#build"
      ]
    }
  }
}
