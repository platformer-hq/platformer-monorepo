{
  "name": "platformer-monorepo",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gql-codegen": "graphql-codegen --config graphql.config.ts",
    "ui-kit:build": "turbo run build --filter=\"@platformer/ui-kit\"",
    "ui-kit:build-icons": "turbo run build-icons --filter=\"@platformer/ui-kit\"",
    "launcher:dev": "turbo run dev --filter=\"@platformer/launcher\"",
    "launcher:build": "turbo run build --filter=\"@platformer/launcher\""
  },
  "dependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/near-operation-file-preset": "^4.0.0",
    "@graphql-codegen/typed-document-node": "^6.1.5",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@nuxt/eslint-config": "^1.15.2",
    "@parcel/watcher": "^2.5.1",
    "@platformer/eslint-config": "workspace:*",
    "baseline-browser-mapping": "^2.9.19",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^9.39.2",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
}
