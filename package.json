{
  "name": "platformer-monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "admin:dev": "cross-env PROJECT=admin-panel nuxt dev --port 5174 --host",
    "admin:build": "cross-env PROJECT=admin-panel nuxt generate --dotenv ./apps/admin-panel/.env.production",
    "launcher:dev": "cross-env PROJECT=launcher nuxt dev --port 5174 --host",
    "launcher:build": "cross-env PROJECT=launcher nuxt generate --dotenv ./apps/launcher/.env.production",
    "build-all": "pnpm run launcher:build && pnpm run admin:build",
    "gql-codegen": "graphql-codegen --config graphql.config.ts",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "icons:build": "tsx layers/ui-kit/build-icons.ts"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "@nuxt/eslint": "1.12.1",
