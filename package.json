    "@pinia/colada": "^1.0.0",
    "@pinia/colada-nuxt": "0.3.2",
    "@pinia/colada-plugin-retry": "^0.2.3",
    "@pinia/nuxt": "0.11.3",
    "@tma.js/bridge": "^2.2.3",
    "@tma.js/sdk-vue": "^1.0.18",
    "@vueuse/core": "^14.2.1",
    "error-kid": "^2.0.0",
    "eruda": "^3.4.3",
    "fp-ts": "^2.16.11",
    "graphql-request": "^7.4.0",
    "nuxt": "^4.3.1",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "valibot": "^1.2.0",
    "vue": "^3.5.28",
    "vue-component-type-helpers": "^3.2.5",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.6"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/near-operation-file-preset": "^4.0.0",
    "@graphql-codegen/typed-document-node": "^6.1.5",
    "@graphql-codegen/typescript": "^5.0.7",
