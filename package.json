    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.6.2",
    "jiti": "^2.6.1",
    "rollup": "^4.60.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "sass-embedded": "^1.97.1",
    "sharp": "^0.34.5",
